# Source fonts for the han-serif build (fetched, not redistributed).
# See: python -m refactored.scripts.fetch_source_fonts
res/fonts/han-serif/SourceHanSerifCN-*.ttf
res/fonts/han-serif/mplus-1m-*.ttf

# Per-weight build intermediates (regenerated by the pipeline)
tmp/json/template_glyf_*.json
tmp/json/template_main_han_serif_*.json
tmp/json/template_main_handwritten_*.json
tmp/json/alphabet_for_pinyin_han_serif_*.json
tmp/json/temp_font_*.json

# Build products, regenerated by the pipeline (see HOW_TO_MAKE_EN.md).
# template_main is useless on its own anyway: its template_glyf partner is
# ignored, so a build always regenerates both.
outputs/Mengshen-HanSerif*.ttf
tmp/json/template_main_han_serif.json

# Private fork notes, not for publication
FORK_NOTES.md
AGENTS.local.md
CLAUDE.local.md
